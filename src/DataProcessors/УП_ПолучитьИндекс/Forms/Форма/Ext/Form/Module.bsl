&НаСервереБезКонтекста
Функция _ОписаниеОшибки(КодСостояния)

	ОписаниеОшибкиТекст = "Неизвестная ошибка";

	ОписаниеОшибки = Новый Соответствие;
	ОписаниеОшибки.Вставить(_HTTP_ОшибкаПараметров(), 	  "Неверный формат данных в запросе или отсутствуют обязательные параметры");
	ОписаниеОшибки.Вставить(_HTTP_ОшибкаАутентификации(), "Некорректный аутентификационный токен");
	ОписаниеОшибки.Вставить(_HTTP_ОшибкаДоступа(), 		  "Некорректный апи-ключ или недостаточно прав для вызова метода");
	ОписаниеОшибки.Вставить(_HTTP_ОшибкаОбработкиДанных(), "Ошибка обработки данных на сервере (некорректные данные или состояние)");
	ОписаниеОшибки.Вставить(_HTTP_СервисНедоступен(),     "Сервис временно недоступен или находится в процессе обновления");

	ОписаниеОшибкиТекстСоответствия = ОписаниеОшибки.Получить(КодСостояния);
	Если ОписаниеОшибкиТекстСоответствия <> Неопределено Тогда
		Возврат ОписаниеОшибкиТекстСоответствия;
	КонецЕсли;

	Возврат ОписаниеОшибкиТекст;

КонецФункции

&НаСервереБезКонтекста
Функция _СформироватьДетальноеОписаниеОшибки(HTTPОтвет, ТелоЗапроса = "")

	ОписаниеОшибкиТекст = _ОписаниеОшибки(HTTPОтвет.КодСостояния);
	URL 				= HTTPОтвет.URL;
	ЭтоАвторизация 		= СтрНайти(URL, "authenticate") > 0;

	Если ЗначениеЗаполнено(ТелоЗапроса) И Не ЭтоАвторизация Тогда
		ТелоЗапросаЖурнал = СтрШаблон("Тело запроса: %1%2", ТелоЗапроса, Символы.ПС);
	Иначе
		ТелоЗапросаЖурнал = "";
	КонецЕсли;

	ДетальноеОписаниеОшибки = СтрШаблон("Описание ошибки: %2%1Запрос API: %3%1%4", Символы.ПС, ОписаниеОшибкиТекст, URL, ТелоЗапросаЖурнал);

	Возврат ДетальноеОписаниеОшибки;
КонецФункции

&НаСервереБезКонтекста
Функция _РезультатОбработкиHTTPОтвета(HTTPОтвет) Экспорт

	Результат = _ОписаниеРезультатаВызоваМетодаAPI();
	КоннекторОбъект = _Коннектор(); // Вызываем _Коннектор один раз

	Результат.КодСостояния = HTTPОтвет.КодСостояния;
	Если _HTTP_OK(HTTPОтвет.КодСостояния) Тогда

		Если HTTPОтвет.Тело.Размер() > 0 Тогда
			ContentType = HTTPОтвет.Заголовки.Получить("Content-Type");
			Если ContentType = "application/octet-stream" Или ContentType = "application/zip" Или ContentType = "application/pdf" Тогда
				Результат.Данные = КоннекторОбъект.КакДвоичныеДанные(HTTPОтвет);
			Иначе
				Попытка
					Данные = КоннекторОбъект.КакJson(HTTPОтвет);
					Результат.Данные = _ФиксированныеДанные(Данные);
				Исключение
					Результат.ПроизошлаОшибка = Истина;
					Результат.ТекстОшибки = "Ошибка при разборе JSON ответа: " + ОписаниеОшибки();
				КонецПопытки;
			Результат.ОтветСервераТекст = КоннекторОбъект.КакТекст(HTTPОтвет);
			КонецЕсли;

		КонецЕсли;

	Иначе

		ОшибкаАутентификации = HTTPОтвет.КодСостояния = _HTTP_ОшибкаАутентификации();

		ДетальноеОписаниеОшибки = _СформироватьДетальноеОписаниеОшибки(HTTPОтвет);
		ОписаниеОшибкиТелоОтвета = КоннекторОбъект.КакТекст(HTTPОтвет);
		Результат.ОтветСервераТекст = ОписаниеОшибкиТелоОтвета;
		Если  ЗначениеЗаполнено(ОписаниеОшибкиТелоОтвета) Тогда
			ДетальноеОписаниеОшибки = СтрШаблон("%1; тело ответа: %2", ДетальноеОписаниеОшибки, ОписаниеОшибкиТелоОтвета);
		КонецЕсли;
		Результат.ПроизошлаОшибка = Истина;
		Результат.ТекстОшибки = ДетальноеОписаниеОшибки;

	КонецЕсли;
	Возврат Результат;

КонецФункции

&НаСервереБезКонтекста
Функция _БазовыйЗапросAPI(ТипЗапроса, Урл, Параметры = Неопределено, Json = Неопределено, Данные = Неопределено)

	Заголовки = Новый Соответствие;
	Заголовки.Вставить("Content-Type", 	  "application/json-patch+json");

	ДопПараметры = Новый Структура;
	ДопПараметры.Вставить("Заголовки", Заголовки);

	Если ЗначениеЗаполнено(Параметры) Тогда
		ДопПараметры.Вставить("ПараметрыЗапроса", Параметры);
	КонецЕсли;

	Если ЗначениеЗаполнено(Json) Тогда
		ДопПараметры.Вставить("Json", Json);
	КонецЕсли;
	Если ЗначениеЗаполнено(Данные) Тогда
		ДопПараметры.Вставить("Данные", Данные);
	КонецЕсли;

	Ответ = Неопределено;
	КоннекторОбъект = _Коннектор();
	// Вызываем _Коннектор один раз

	Если ТипЗапроса = "GET" Тогда
		Ответ = КоннекторОбъект.Get(	_Хосты().API + Урл,, ДопПараметры);
	ИначеЕсли ТипЗапроса = "POST" Тогда
		Ответ = КоннекторОбъект.Post(	_Хосты().API + Урл,, ДопПараметры);
	ИначеЕсли ТипЗапроса = "PUT" Тогда
		Ответ = КоннекторОбъект.Put(	_Хосты().API + Урл,, ДопПараметры);
	ИначеЕсли ТипЗапроса = "PATCH" Тогда
		Ответ = КоннекторОбъект.Patch(	_Хосты().API + Урл,, ДопПараметры);
	ИначеЕсли ТипЗапроса = "DELETE" Тогда
		Ответ = КоннекторОбъект.Delete(_Хосты().API + Урл,, ДопПараметры);
	Иначе
		ДетальноеОписаниеОшибки = НСтр("ru = 'Неизвестный тип HTTP-запроса'");
		// КЭДО_Сервер.ЗаписьЖурнала (предполагается, что это доступная глобальная функция)

		Результат = _ОписаниеРезультатаВызоваМетодаAPI();
		Результат.ПроизошлаОшибка = Истина;
		Результат.ТекстОшибки = ДетальноеОписаниеОшибки;

		Возврат Результат;
	КонецЕсли;
	// ТелоЗапроса для логирования формируется здесь, но не используется в _РезультатОбработкиHTTPОтвета
	// Если нужно логировать тело запроса, его следует передать в _РезультатОбработкиHTTPОтвета
	// ТелоЗапроса = ?(ЗначениеЗаполнено(Json), КоннекторОбъект.ОбъектВJson(Json), "");
	Возврат _РезультатОбработкиHTTPОтвета(Ответ);
КонецФункции

